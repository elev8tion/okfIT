{
  "name": "okfit",
  "version": "0.3.2",
  "description": "Convert docs into Open Knowledge Format bundles and serve them to MCP agents.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./setup": {
      "types": "./dist/setup-artifacts.d.ts",
      "import": "./dist/setup-artifacts.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "okfit": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "assets/logo.png",
    "assets/demo.gif",
    "docs/mcp-clients.md",
    "skills",
    "examples"
  ],
  "keywords": [
    "okf",
    "open-knowledge-format",
    "mcp",
    "agent-memory",
    "llm",
    "docs",
    "rag",
    "markdown"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts src/setup-artifacts.ts --format esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "okfit": "node dist/cli.js",
    "demo": "node dist/cli.js demo",
    "publish:npm": "node scripts/publish-npm-readme.mjs",
    "prepublishOnly": "pnpm build && pnpm test && pnpm typecheck"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.3",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.2.0",
    "minimatch": "^10.0.1",
    "minisearch": "^7.1.2",
    "p-limit": "^6.2.0",
    "picocolors": "^1.1.1",
    "robots-parser": "^3.0.1",
    "turndown": "^7.2.0",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.1",
    "@types/turndown": "^5.0.5",
    "eslint": "^9.29.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/okfIT/okfIT.git"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
